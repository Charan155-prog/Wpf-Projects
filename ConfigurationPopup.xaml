<UserControl x:Class="SterilizationGenie.Views.ConfigurationPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation">

    <Grid>
        <Border Background="#BB000000" />

        <Border Width="800" MaxHeight="580"
                Background="#FFF0F0F0"
                BorderBrush="#FFFFFF" BorderThickness="1"
                HorizontalAlignment="Center" VerticalAlignment="Center">

            <Grid>
                <Border Height="40" Background="#FF282828" VerticalAlignment="Top">
                    <Grid>
                        <Label Content="Sterilization Configuration" HorizontalAlignment="Left" FontSize="20" Foreground="White" FontStyle="Italic" Margin="10,0,0,0" VerticalAlignment="Center"/>

                        <Border Cursor="Hand" Height="30" Width="30" CornerRadius="50" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,5,5,0">
                            <Border.Background>
                                <RadialGradientBrush>
                                    <GradientStop Color="#FF500000" Offset="0.968"/>
                                    <GradientStop Color="Red"/>
                                </RadialGradientBrush>
                            </Border.Background>
                            <Button Background="Transparent" BorderThickness="0" Foreground="White" FontWeight="Bold" FontSize="18" TextElement.FontFamily="Arial"
                                    Content="x" Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Command="{Binding CloseConfigurationPopupCommand}" Margin="0,0,0,4">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Border>
                    </Grid>
                </Border>

                <Grid Margin="0,40,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="65" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#FF16144E">
                        <StackPanel Margin="0,20,0,0">
                            <Border Background="#FF2D299E" Padding="5,20" Height="100">
                                <TextBlock Text="Preferences" Foreground="White" FontSize="14" FontStyle="Italic" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="270" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#FFF0F0F0">
                        <Grid Margin="15,20,15,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <!-- NEW: Online Mode row -->
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Row 0: Source -->
                            <StackPanel Grid.Row="0" Visibility="Collapsed" Orientation="Vertical" Margin="5,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Source" FontWeight="Bold" FontSize="17" FontFamily="Calibri" Foreground="Black" Width="100" VerticalAlignment="Center" />
                                    <TextBlock Text="Select one or more .xlsx workbooks during import. Data is synchronized with local SQLite." Foreground="Black" FontSize="15" FontFamily="Calibri" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border Background="#FF8388E6" Height="2" Margin="0,15,-15,15" HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <!-- Row 1: Options (offline checkboxes — unchanged) -->
                            <StackPanel Grid.Row="0" Orientation="Vertical" Margin="5,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Options" FontWeight="Bold" FontSize="17" FontFamily="Calibri" Foreground="Black" Width="100" VerticalAlignment="Center" />
                                    <CheckBox IsChecked="{Binding ParseExistingData}" Margin="0,0,20,0">
                                        <CheckBox.LayoutTransform>
                                            <ScaleTransform ScaleX="1.2" ScaleY="1.2" />
                                        </CheckBox.LayoutTransform>
                                        <TextBlock Text="Parse Existing Data" FontFamily="Calibri" FontSize="15" Foreground="Black" FontWeight="SemiBold"/>
                                    </CheckBox>
                                    <CheckBox IsChecked="{Binding WatchNewRowsData}">
                                        <CheckBox.Style>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="Opacity" Value="1"/>
                                            </Style>
                                        </CheckBox.Style>
                                        <CheckBox.LayoutTransform>
                                            <ScaleTransform ScaleX="1.2" ScaleY="1.2" />
                                        </CheckBox.LayoutTransform>
                                        <TextBlock Text="Watch for New Rows" FontFamily="Calibri" FontSize="15" Foreground="Black" FontWeight="SemiBold"/>
                                    </CheckBox>
                                </StackPanel>
                                <Border Background="#FF8388E6" Height="2" Margin="0,15,-15,15" HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <!-- Row 2: Actions (offline import — unchanged) -->
                            <StackPanel Grid.Row="2" Orientation="Vertical" Margin="5,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Offline" FontWeight="Bold" FontSize="17" FontFamily="Calibri" Foreground="Black" Width="100" VerticalAlignment="Center" />
                                    <Button Height="30" Padding="15,0" Margin="0,0,10,0" Command="{Binding ImportWorkbookCommand}" Background="#E0E0E0">
                                        <TextBlock Text="Import Excel Data" Foreground="Black" FontFamily="Calibri" FontSize="15" FontWeight="SemiBold" />
                                    </Button>
                                    <Button Height="30" Padding="15,0" Command="{Binding WipeDatabaseCommand}" Background="#FFDCD0">
                                        <TextBlock Text="Wipe DB" Foreground="#990000" FontFamily="Calibri" FontSize="15" FontWeight="Bold" />
                                    </Button>
                                </StackPanel>
                                <Border Background="#FF8388E6" Height="2" Margin="0,15,-15,15" HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <!-- Row 3: Cache DB status (unchanged) -->
                            <StackPanel Grid.Row="4" Orientation="Vertical" Margin="5,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Cache DB" FontWeight="Bold" FontSize="17" FontFamily="Calibri" Foreground="Black" Width="100" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding DatabaseConnectionStatus}" Foreground="{Binding DatabaseConnectionColor}" FontSize="15" FontFamily="Calibri" VerticalAlignment="Center" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="100,10,0,0">
                                    <TextBlock Text="&#x1F4A1;" Foreground="#FF66A3" FontSize="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding LastActionMessage}" Foreground="OrangeRed" FontFamily="Calibri" FontSize="14" />
                                </StackPanel>
                                <Border Background="#FF8388E6" Height="2" Margin="0,15,-15,15" HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <!-- Row 4: NEW — Online Mode / Live Excel section -->
                            <StackPanel Grid.Row="1" Orientation="Vertical" Margin="5,0,0,10">
                                <!-- Section header -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Online" FontWeight="Bold" FontSize="17" FontFamily="Calibri" Foreground="#1A1A8E" Width="100" VerticalAlignment="Center" />
                                    <Border Background="#1A1A8E" CornerRadius="3" Padding="8,3" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <TextBlock Text="LIVE MODE" Foreground="White" FontSize="11" FontWeight="Bold" />
                                    </Border>
                                    <TextBlock Text="Select a live-generated Excel file to monitor new rows in real time." Foreground="#333333" FontSize="13" FontFamily="Calibri" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="350"/>
                                </StackPanel>

                                <!-- File picker row -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Height="32" Padding="15,0" Margin="0,0,10,0"
                                            Command="{Binding SelectOnlineFileCommand}"
                                            Background="#2D299E"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                                        Opacity="{TemplateBinding Opacity}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Opacity" Value="1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.45"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <!-- folder icon -->
                                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Select Live Excel" FontFamily="Calibri" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Selected file path display -->
                                    <Border Background="#FFFAF0" BorderBrush="#AAAACC" BorderThickness="1" CornerRadius="2" Padding="8,4" MinWidth="200" MaxWidth="360" VerticalAlignment="Center">
                                        <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#222266" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="340">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding OnlineWatchFilePath}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasOnlineWatchFile}" Value="False">
                                                            <Setter Property="Text" Value="No file selected" />
                                                            <Setter Property="Foreground" Value="#999999" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- Green tick shown when file is valid -->
                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#2AA845"
                                               VerticalAlignment="Center" Margin="8,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasOnlineWatchFile}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Instruction hint -->
                                <TextBlock Margin="0,0,0,0" FontFamily="Calibri" FontSize="12" Foreground="#555577" TextWrapping="Wrap" MaxWidth="620">
                                    <Run Text="&#x2139;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                    <Run Text=" After selecting a file, enable "/>
                                    <Run Text="Watch for New Rows" FontWeight="Bold"/>
                                    <Run Text=" above, close this popup, then toggle "/>
                                    <Run Text="Online" FontWeight="Bold"/>
                                    <Run Text=" in the top bar to start live monitoring. The online dashboard will replace the offline view."/>
                                </TextBlock>
                                <Border Background="#FF8388E6" Height="2" Margin="0,15,-15,15" HorizontalAlignment="Stretch" />
                            </StackPanel>
                          
                            <!-- Row 5: spacer -->
                            <Grid Grid.Row="5" />

                            <!-- Row 6: Ok button -->
                            <Button Grid.Row="6" Content="Ok" Command="{Binding CloseConfigurationPopupCommand}" Height="30" Width="90"
                                    Margin="0,10,0,10" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                    Background="#6B4BAE" Foreground="White" FontSize="14" FontWeight="SemiBold" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
