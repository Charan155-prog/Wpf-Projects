<UserControl x:Class="SterilizationGenie.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- Dark tooltip — applied to every ToolTip in this UserControl -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#1E1E2E" />
            <Setter Property="Foreground" Value="#F0F0FF" />
            <Setter Property="BorderBrush" Value="#4A4A7A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HasDropShadow" Value="True" />
        </Style>

        <Style x:Key="DarkComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFEAEAEA" />
            <Setter Property="Background" Value="#2A2A35" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#3A7AB8" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A7AB8" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SelectedComboOverlayTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="10,0,28,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <Style x:Key="SensorHeaderDropdownCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFEAEAEA" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="2,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="TelerikLikeComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="#F4F7FB" />
            <Setter Property="Foreground" Value="#12161F" />
            <Setter Property="BorderBrush" Value="#6C7A90" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="TelerikLikeDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="34" />
            <Setter Property="Width" Value="150" />
            <Setter Property="Background" Value="#F4F7FB" />
            <Setter Property="Foreground" Value="#12161F" />
            <Setter Property="BorderBrush" Value="#6C7A90" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="6,0" />
        </Style>

        <Style x:Key="TelerikLikeIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="#3478B8" />
            <Setter Property="BorderBrush" Value="#6C7A90" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3A3A3A" />
                    <Setter Property="BorderBrush" Value="#444444" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3F8DD4" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Live stat card style used in the online mode header band -->
        <Style x:Key="LiveStatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1E1E2A" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="MinWidth" Value="120" />
        </Style>
    </UserControl.Resources>

    <!-- Root grid: stacks the OFFLINE view and the ONLINE view. Only one is visible at a time. -->
    <Grid Background="#FF282828">

        <!-- ═══════════════════════════════════════════════════════════════════════
             OFFLINE MODE — existing layout, hidden when IsOnline = true
             ═══════════════════════════════════════════════════════════════════════ -->
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsOnline}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="230" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="Transparent" BorderThickness="0,0,1,0" ClipToBounds="True">
                <Grid Margin="14,6,14,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#222222"
                            BorderBrush="#444444"
                            BorderThickness="1"
                            Padding="16,12,16,10"
                            Margin="0,0,0,6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                        Text="{Binding TrendChartTitle}"
                                        FontSize="17"
                                        Foreground="Goldenrod"
                                        FontWeight="SemiBold"
                                        VerticalAlignment="Top"
                                        Margin="4,0,0,10" />

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                        Width="210"
                                        Orientation="Vertical"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="All Cycles" Foreground="#FFEAEAEA" FontSize="11" Margin="0,0,0,4" />
                                    <Grid Height="34">
                                        <ComboBox Height="34"
                                              Style="{StaticResource TelerikLikeComboBoxStyle}"
                                              Opacity="0.02"
                                              Background="#F2F2F2"
                                              Foreground="Transparent"
                                              BorderBrush="#555555"
                                              Padding="8,4"
                                              ItemsSource="{Binding AllCycleOptions}"
                                              SelectedIndex="-1"
                                              IsTextSearchEnabled="False"
                                              MaxDropDownHeight="320">
                                            <ComboBox.Resources>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A35" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#EEEEEE" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#EEEEEE" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#BBBBBB" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3A7AB8" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                            </ComboBox.Resources>
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding DisplayName}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          Style="{StaticResource SensorHeaderDropdownCheckBoxStyle}"
                                                          Cursor="Hand" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Border Background="#F2F2F2"
                                            BorderBrush="#555555"
                                            BorderThickness="1"
                                            IsHitTestVisible="False">
                                            <Grid>
                                                <TextBlock Text="{Binding SelectedCyclesSummary}"
                                                       Foreground="#111111"
                                                       Margin="14,0,36,0"
                                                       Style="{StaticResource SelectedComboOverlayTextStyle}" />
                                                <TextBlock Text="&#xE70D;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       Foreground="#555555"
                                                       FontSize="10"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,12,0" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                        Width="215"
                                        Orientation="Vertical"
                                        VerticalAlignment="Top"
                                        Margin="12,0,0,0">
                                    <TextBlock Text="Comparison View" Foreground="#FFEAEAEA" FontSize="11" Margin="0,0,0,4" />
                                    <Grid Height="34">
                                        <ComboBox Height="34"
                                              Style="{StaticResource TelerikLikeComboBoxStyle}"
                                              Opacity="0.02"
                                              Background="#F2F2F2"
                                              Foreground="Transparent"
                                              BorderBrush="#555555"
                                              Padding="8,4"
                                              ItemContainerStyle="{StaticResource DarkComboItemStyle}"
                                              ItemsSource="{Binding ChartRepresentations}"
                                              SelectedItem="{Binding SelectedRepresentation, Mode=TwoWay}"
                                              IsTextSearchEnabled="False"
                                              MaxDropDownHeight="240">
                                            <ComboBox.Resources>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A35" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#EEEEEE" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#EEEEEE" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#BBBBBB" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3A7AB8" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                            </ComboBox.Resources>
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Foreground="#EEEEEE"
                                                               Padding="4,2"
                                                               FontSize="12" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Border Background="#F2F2F2"
                                            BorderBrush="#555555"
                                            BorderThickness="1"
                                            IsHitTestVisible="False">
                                            <Grid>
                                                <TextBlock Text="{Binding SelectedRepresentationDisplayName}"
                                                       Foreground="#111111"
                                                       Margin="14,0,36,0"
                                                       Style="{StaticResource SelectedComboOverlayTextStyle}" />
                                                <TextBlock Text="&#xE70D;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       Foreground="#555555"
                                                       FontSize="10"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,12,0" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                        Width="255"
                                        Orientation="Vertical"
                                        VerticalAlignment="Top"
                                        Margin="12,0,0,0"
                                        Visibility="{Binding ShowSensorSelector, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Sensor Headers" Foreground="#FFEAEAEA" FontSize="11" Margin="0,0,0,4" />
                                    <Grid Height="34">
                                        <ComboBox Height="34"
                                              Style="{StaticResource TelerikLikeComboBoxStyle}"
                                              Opacity="0.02"
                                              Background="#F2F2F2"
                                              Foreground="Transparent"
                                              BorderBrush="#555555"
                                              Padding="8,4"
                                              ItemContainerStyle="{StaticResource DarkComboItemStyle}"
                                              ItemsSource="{Binding ComparisonMetricOptions}"
                                              SelectedIndex="-1"
                                              IsTextSearchEnabled="False"
                                              MaxDropDownHeight="320">
                                            <ComboBox.Resources>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A35" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#EEEEEE" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#EEEEEE" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#BBBBBB" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3A7AB8" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                            </ComboBox.Resources>
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding DisplayName}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          Style="{StaticResource SensorHeaderDropdownCheckBoxStyle}"
                                                          Cursor="Hand" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Border Background="#F2F2F2"
                                            BorderBrush="#555555"
                                            BorderThickness="1"
                                            IsHitTestVisible="False">
                                            <Grid>
                                                <TextBlock Text="{Binding SelectedMetricsSummary}"
                                                       Foreground="#111111"
                                                       Margin="14,0,36,0"
                                                       Style="{StaticResource SelectedComboOverlayTextStyle}" />
                                                <TextBlock Text="&#xE70D;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       Foreground="#555555"
                                                       FontSize="10"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,12,0" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="3"
        Width="150"
        Orientation="Vertical"
        VerticalAlignment="Top"
        Margin="12,0,0,0">

                                    <TextBlock Text="Date"
               Foreground="#FFEAEA"
               FontSize="11"
               Margin="0,0,0,4" />

                                    <DatePicker Height="34"
                Style="{StaticResource TelerikLikeDatePickerStyle}"
                Width="150"
                SelectedDate="{Binding SelectedChartDate, Mode=TwoWay}"
                SelectedDateFormat="Short"
                Background="#F2F2F2"
                Foreground="#111111"
                BorderBrush="#555555"
                VerticalContentAlignment="Center"
                Padding="6,0">

                                        <!-- Fix Text Alignment -->
                                        <DatePicker.Resources>

                                            <!-- TextBox inside DatePicker -->
                                            <Style TargetType="DatePickerTextBox">
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="6,0"/>
                                            </Style>

                                            <!-- Calendar Day Styling -->
                                            <Style TargetType="CalendarDayButton">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Background" Value="Transparent"/>

                                                <Style.Triggers>
                                                    <!-- Today -->
                                                    <Trigger Property="IsToday" Value="True">
                                                        <Setter Property="BorderBrush" Value="#3A7AB8"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                    </Trigger>

                                                    <!-- Selected -->
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#3A7AB8"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>

                                                    <!-- Inactive days -->
                                                    <Trigger Property="IsInactive" Value="True">
                                                        <Setter Property="Foreground" Value="#777"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>

                                        </DatePicker.Resources>

                                        <!-- Calendar Popup Styling -->
                                        <DatePicker.CalendarStyle>
                                            <Style TargetType="Calendar">
                                                <Setter Property="Background" Value="#2A2A35"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#555"/>
                                            </Style>
                                        </DatePicker.CalendarStyle>

                                    </DatePicker>
                                </StackPanel>

                                <StackPanel Grid.Column="4"
                                        Width="116"
                                        Orientation="Vertical"
                                        VerticalAlignment="Top"
                                        Margin="12,0,0,0">
                                    <TextBlock Text="View Mode" Foreground="#FFEAEAEA" FontSize="11" Margin="0,0,0,4" />
                                    <StackPanel Orientation="Horizontal" Height="34">
                                        <Button Width="38" Height="34"
                                                Style="{StaticResource TelerikLikeIconButtonStyle}"
                                                Command="{Binding ToggleChartTypeCommand}"
                                                IsEnabled="{Binding CanToggleChartMode}"
                                                Cursor="Hand"
                                                BorderThickness="1"
                                                Padding="0">
                                            <Button.ToolTip>
                                                <ToolTip>
                                                    <TextBlock Text="{Binding ChartModeLabel}" Foreground="#F0F0FF" />
                                                </ToolTip>
                                            </Button.ToolTip>
                                            <Grid>
                                                <Viewbox Width="18" Height="18">
                                                    <Canvas Width="24" Height="24">
                                                        <Canvas.Style>
                                                            <Style TargetType="Canvas">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsBarChartRepresentation}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Canvas.Style>
                                                        <Rectangle Canvas.Left="3" Canvas.Top="10" Width="4" Height="10" Fill="White" />
                                                        <Rectangle Canvas.Left="10" Canvas.Top="5" Width="4" Height="15" Fill="White" />
                                                        <Rectangle Canvas.Left="17" Canvas.Top="13" Width="4" Height="7" Fill="White" />
                                                    </Canvas>
                                                </Viewbox>
                                                <Viewbox Width="18" Height="18">
                                                    <Canvas Width="24" Height="24">
                                                        <Canvas.Style>
                                                            <Style TargetType="Canvas">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsBarChartRepresentation}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Canvas.Style>
                                                        <Polyline Points="2,18 7,10 12,14 17,6 22,10"
                                                                  Stroke="White" StrokeThickness="2"
                                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                                  Fill="Transparent" />
                                                        <Ellipse Canvas.Left="5.5" Canvas.Top="8.5" Width="3" Height="3" Fill="White" />
                                                        <Ellipse Canvas.Left="10.5" Canvas.Top="12.5" Width="3" Height="3" Fill="White" />
                                                        <Ellipse Canvas.Left="15.5" Canvas.Top="4.5" Width="3" Height="3" Fill="White" />
                                                        <Ellipse Canvas.Left="20.5" Canvas.Top="8.5" Width="3" Height="3" Fill="White" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Grid>
                                        </Button>

                                        <Button Width="38" Height="34"
                                                Margin="8,0,0,0"
                                                Style="{StaticResource TelerikLikeIconButtonStyle}"
                                                Command="{Binding ToggleExportPanelCommand}"
                                                IsEnabled="{Binding CanToggleChartMode}"
                                                Cursor="Hand"
                                                BorderThickness="1"
                                                Padding="0"
                                                >
                                            <Button.ToolTip>
                                                <ToolTip>
                                                    <TextBlock Text="Export current view" Foreground="#F0F0FF" />
                                                </ToolTip>
                                            </Button.ToolTip>
                                            <Viewbox Width="18" Height="18">
                                                <Canvas Width="24" Height="24">
                                                    <Path Stroke="White" StrokeThickness="2" Fill="Transparent"
                                                          Data="M3,15 L3,20 L21,20 L21,15" />
                                                    <Path Stroke="White" StrokeThickness="2" Fill="Transparent"
                                                          Data="M12,3 L12,15 M7,10 L12,15 L17,10" />
                                                </Canvas>
                                            </Viewbox>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <lvc:CartesianChart x:Name="MainChart"
                                            DisableAnimations="True"
                                            LegendLocation="Right"
                                            Series="{Binding OfflineMainChartSeries}"
                                            DataClick="MainChart_OnDataClick"
                                            Visibility="{Binding HasRenderableSeries, Converter={StaticResource BoolToVisibilityConverter}}">
                            <lvc:CartesianChart.DataTooltip>
                                <lvc:DefaultTooltip Background="#222" Foreground="White" />
                            </lvc:CartesianChart.DataTooltip>
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="{Binding XAxisTitle}" Foreground="Goldenrod" FontSize="12"
                                           Labels="{Binding XLabels}" LabelFormatter="{Binding XAxisFormatter}" LabelsRotation="-45">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Step="{Binding XAxisSeparatorStep}" StrokeThickness="0.25" Stroke="White" StrokeDashArray="15" />
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="{Binding YAxisTitle}" Foreground="Goldenrod" FontSize="12"
                                          MinValue="{Binding YAxisMin}" MaxValue="{Binding YAxisMax}"
                                          LabelFormatter="{Binding YAxisFormatter}">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator StrokeThickness="0.25" Stroke="White" StrokeDashArray="15" />
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>

                        <!-- Export panel -->
                        <Border HorizontalAlignment="Right"
                                VerticalAlignment="Stretch"
                                Width="360"
                                Margin="0,8,8,8"
                                Background="#F2202028"
                                BorderBrush="#4A90E2"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16"
                                Panel.ZIndex="20"
                                Visibility="{Binding IsExportPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Export current view"
                                               Foreground="Goldenrod"
                                               FontWeight="SemiBold"
                                               FontSize="15"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Width="26" Height="26"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="#FFEAEAEA"
                                            Content="X"
                                            Cursor="Hand"
                                            Command="{Binding CloseExportPanelCommand}" />
                                </Grid>

                                <TextBlock Grid.Row="1"
                                           Text="{Binding SelectedRepresentationDisplayName}"
                                           Foreground="#FFEAEAEA"
                                           FontSize="13"
                                           Margin="0,8,0,8" />

                                <Border Grid.Row="2"
                                        Background="#10FFFFFF"
                                        BorderBrush="#33FFFFFF"
                                        BorderThickness="1"
                                        Padding="10"
                                        CornerRadius="4">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBlock Text="{Binding ExportPanelSummary}"
                                                   Foreground="#FFEAEAEA"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                    </ScrollViewer>
                                </Border>

                                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                    <Button x:Name="ExportSavePngButton"
                                            Content="Save chart (PNG)"
                                            Padding="12,6"
                                            Margin="0,0,8,0"
                                            Background="#3A7AB8"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="ExportSavePngButton_Click" />
                                    <Button x:Name="ExportSaveDetailsButton"
                                            Content="Save details (TXT)"
                                            Padding="12,6"
                                            Background="#3A7AB8"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="ExportSaveDetailsButton_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Background="#1A282828">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasRenderableSeries}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding EmptyStateMessage}"
                                       Foreground="#88FFFFFF"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       MaxWidth="360" />
                        </Border>

                        <!-- Drill-down overlay -->
                        <Border Background="#F9202020"
                                Panel.ZIndex="10"
                                Padding="20"
                                CornerRadius="6"
                                BorderBrush="#4A90E2"
                                BorderThickness="1"
                                Margin="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDrillDownOpen}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,15" LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="{Binding DrillDownTitle}" Foreground="White" FontSize="20" FontWeight="Bold" />
                                        <TextBlock Text="{Binding DrillDownSubtitle}" Foreground="#AAAAAA" FontSize="14" Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding DrillDownPointSummary}" Foreground="#F4B740" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap" MaxWidth="760" />
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right"
                                            Content="Close"
                                            Command="{Binding CloseDrillDownCommand}"
                                            Width="80"
                                            Height="30"
                                            Background="#333"
                                            Foreground="White"
                                            BorderBrush="#555"
                                            Cursor="Hand" />
                                </DockPanel>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>

                                    <lvc:CartesianChart Grid.Column="0"
                                                        DisableAnimations="True"
                                                        Series="{Binding DrillDownSeries}"
                                                        LegendLocation="Right"
                                                        Margin="0,0,20,0">
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis Title="{Binding DrillDownXAxisTitle}"
                                                      Labels="{Binding DrillDownXLabels}"
                                                      LabelFormatter="{Binding DrillDownXFormatter}"
                                                      Foreground="Goldenrod">
                                                <lvc:Axis.Separator>
                                                    <lvc:Separator Stroke="#444" />
                                                </lvc:Axis.Separator>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis Title="{Binding DrillDownYAxisTitle}"
                                                      Foreground="Goldenrod">
                                                <lvc:Axis.Separator>
                                                    <lvc:Separator Stroke="#444" />
                                                </lvc:Axis.Separator>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisY>
                                        <lvc:CartesianChart.DataTooltip>
                                            <lvc:DefaultTooltip Background="#222" Foreground="White" />
                                        </lvc:CartesianChart.DataTooltip>
                                    </lvc:CartesianChart>

                                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding DrillDownStatRows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#2A2A35" Margin="0,0,0,8" Padding="12,8" CornerRadius="4">
                                                        <DockPanel>
                                                            <TextBlock Text="{Binding Title}" Foreground="#AAAAAA" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                                            <TextBlock Text="{Binding Value}" Foreground="White" FontWeight="SemiBold" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Right panel: Live Warnings -->
            <Border Grid.Column="1" Background="#FF282828" BorderBrush="#FF444444" BorderThickness="1,0,0,0">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Live Warnings"
                               FontSize="18"
                               Foreground="Goldenrod"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12" />

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AlertTiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2E2E3A"
                                            BorderBrush="#555555"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Margin="0,0,0,12"
                                            Padding="14,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{Binding BadgeColor}"
                                                        CornerRadius="3"
                                                        Padding="7,3"
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding ClassCode}"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               FontSize="12" />
                                                </Border>
                                                <TextBlock Text="{Binding PriorityLabel}"
                                                           Foreground="#AAAAAA"
                                                           FontSize="11"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>

                                            <TextBlock Text="{Binding SuggestedAction}"
                                                       Foreground="#F4B740"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       LineHeight="18" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════════════
             ONLINE MODE — full-screen live dashboard, shown only when IsOnline=true
             ═══════════════════════════════════════════════════════════════════════ -->
