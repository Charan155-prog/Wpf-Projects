                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding OnlineWatchFilePath}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasOnlineWatchFile}" Value="False">
                                                <Setter Property="Text" Value="No file selected" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- Centre: representation controls -->
                    <!--<StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
