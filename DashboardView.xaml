<UserControl x:Class="SterilizationGenie.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="DarkComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFEAEAEA" />
            <Setter Property="Background" Value="#2A2A35" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#3A7AB8" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A7AB8" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SelectedComboOverlayTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="10,0,28,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <Style x:Key="SensorHeaderDropdownCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFEAEAEA" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="2,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#FF282828">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="230" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="Transparent" BorderThickness="0,0,1,0" ClipToBounds="True">
            <Grid Margin="15,8,18,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#222222"
                        BorderBrush="#444444"
                        BorderThickness="1"
                        Padding="18,16,18,14"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                    Text="{Binding TrendChartTitle}"
                                    FontSize="17"
                                    Foreground="Goldenrod"
                                    FontWeight="SemiBold"
                                   VerticalAlignment="Top"
                                   Margin="4,0,0,16" />

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="215" />
                                <ColumnDefinition Width="255" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Orientation="Vertical"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding HasCycleData, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Failed Cycles" Foreground="#FF8080" FontSize="11" Margin="0,0,0,4" />
                            <Grid Height="34">
                                <ComboBox Height="34"
                                          ItemsSource="{Binding FailedCycleOptions}"
                                          SelectedItem="{Binding SelectedFailedCycle, Mode=TwoWay}"
                                          Background="#F2F2F2"
                                          Foreground="#111111"
                                          BorderBrush="#884444"
                                          ItemContainerStyle="{StaticResource DarkComboItemStyle}"
                                          DisplayMemberPath="DisplayName">
                                    <ComboBox.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A35" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#EEEEEE" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#EEEEEE" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#BBBBBB" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#AA3333" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                    </ComboBox.Resources>
                                </ComboBox>
                                <TextBlock Text="{Binding SelectedFailedCycleLabel}"
                                           Foreground="#AA3333"
                                           Style="{StaticResource SelectedComboOverlayTextStyle}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Vertical"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0"
                                    Visibility="{Binding HasCycleData, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Good Cycles" Foreground="#80CC80" FontSize="11" Margin="0,0,0,4" />
                            <Grid Height="34">
                                <ComboBox Height="34"
                                          ItemsSource="{Binding GoodCycleOptions}"
                                          SelectedItem="{Binding SelectedGoodCycle, Mode=TwoWay}"
                                          Background="#F2F2F2"
                                          Foreground="#111111"
                                          BorderBrush="#447744"
                                          ItemContainerStyle="{StaticResource DarkComboItemStyle}"
                                          DisplayMemberPath="DisplayName">
                                    <ComboBox.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A35" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#EEEEEE" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#EEEEEE" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#BBBBBB" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#336633" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                    </ComboBox.Resources>
                                </ComboBox>
                                <TextBlock Text="{Binding SelectedGoodCycleLabel}"
                                           Foreground="#2F8F2F"
                                           Style="{StaticResource SelectedComboOverlayTextStyle}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Orientation="Vertical"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0">
                            <TextBlock Text="Comparison View" Foreground="#FFEAEAEA" FontSize="11" Margin="0,0,0,4" />
                            <Grid Height="34">
                                <ComboBox Height="34"
                                          ItemsSource="{Binding ChartRepresentations}"
                                          SelectedItem="{Binding SelectedRepresentation, Mode=TwoWay}"
                                          Background="#F2F2F2"
                                          Foreground="#111111"
                                          BorderBrush="#555555"
                                          ItemContainerStyle="{StaticResource DarkComboItemStyle}"
                                          DisplayMemberPath="DisplayName">
                                    <ComboBox.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A35" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#EEEEEE" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#EEEEEE" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#BBBBBB" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3A7AB8" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                    </ComboBox.Resources>
                                </ComboBox>
                                <TextBlock Text="{Binding SelectedRepresentationDisplayName}"
                                           Foreground="#111111"
                                           Style="{StaticResource SelectedComboOverlayTextStyle}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="3"
                                    Orientation="Vertical"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0"
                                    Visibility="{Binding ShowSensorSelector, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Sensor Headers" Foreground="#FFEAEAEA" FontSize="11" Margin="0,0,0,4" />
                            <Grid Height="34">
                                <ComboBox Height="34"
                                          Opacity="0.02"
                                          Background="#F2F2F2"
                                          Foreground="Transparent"
                                          BorderBrush="#555555"
                                          Padding="8,4"
                                          ItemContainerStyle="{StaticResource DarkComboItemStyle}"
                                          ItemsSource="{Binding ComparisonMetricOptions}"
                                          SelectedIndex="-1"
                                          IsTextSearchEnabled="False"
                                          MaxDropDownHeight="320">
                                    <ComboBox.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A35" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#EEEEEE" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#EEEEEE" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#BBBBBB" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3A7AB8" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                    </ComboBox.Resources>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding DisplayName}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Style="{StaticResource SensorHeaderDropdownCheckBoxStyle}"
                                                      Cursor="Hand" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Border Background="#F2F2F2"
                                        BorderBrush="#555555"
                                        BorderThickness="1"
                                        IsHitTestVisible="False">
                                    <Grid>
                                        <TextBlock Text="{Binding SelectedMetricsSummary}"
                                                   Foreground="#111111"
                                                   Margin="14,0,36,0"
                                                   Style="{StaticResource SelectedComboOverlayTextStyle}" />
                                        <TextBlock Text="&#xE70D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Foreground="#555555"
                                                   FontSize="10"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>

                            <StackPanel Grid.Column="4"
            Orientation="Vertical"
            VerticalAlignment="Center"
            Margin="12,0,0,0">

                                <TextBlock Text="Date"
               Foreground="#FFEAEA"
               FontSize="11"
               Margin="0,0,0,4" />

                                <DatePicker Height="34"
                Width="150"
                SelectedDate="{Binding SelectedChartDate, Mode=TwoWay}"
                SelectedDateFormat="Short"
                Background="#F2F2F2"
                Foreground="#111111"
                BorderBrush="#555555"
                VerticalContentAlignment="Center"
                Padding="6,0">

                                    <!-- Fix Text Alignment -->
                                    <DatePicker.Resources>

                                        <!-- TextBox inside DatePicker -->
                                        <Style TargetType="DatePickerTextBox">
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="6,0"/>
                                        </Style>

                                        <!-- Calendar Day Styling -->
                                        <Style TargetType="CalendarDayButton">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Background" Value="Transparent"/>

                                            <Style.Triggers>
                                                <!-- Today -->
                                                <Trigger Property="IsToday" Value="True">
                                                    <Setter Property="BorderBrush" Value="#3A7AB8"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </Trigger>

                                                <!-- Selected -->
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#3A7AB8"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>

                                                <!-- Inactive days -->
                                                <Trigger Property="IsInactive" Value="True">
                                                    <Setter Property="Foreground" Value="#777"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>

                                    </DatePicker.Resources>

                                    <!-- Calendar Popup Styling -->
                                    <DatePicker.CalendarStyle>
                                        <Style TargetType="Calendar">
                                            <Setter Property="Background" Value="#2A2A35"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#555"/>
                                        </Style>
                                    </DatePicker.CalendarStyle>

                                </DatePicker>
                            </StackPanel>

                            <StackPanel Grid.Column="5"
                                    Orientation="Vertical"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0">
                            <TextBlock Text="Representation Mode" Foreground="#FFEAEAEA" FontSize="11" Margin="0,0,0,4" />
                            <Grid Height="34">
                                <ToggleButton Height="34"
                                              Cursor="Hand"
                                              Command="{Binding ToggleChartTypeCommand}"
                                              IsChecked="{Binding IsBarChartRepresentation, Mode=OneWay}"
                                              BorderBrush="#555555"
                                              Foreground="Transparent"
                                              IsEnabled="{Binding CanToggleChartMode}">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Background" Value="#4F7FAF" />
                                            <Setter Property="Foreground" Value="#FFFFFF" />
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#5A5A5A" />
                                                    <Setter Property="Foreground" Value="#DDDDDD" />
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Background" Value="#2F6699" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                                <TextBlock Text="{Binding ChartModeLabel}"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="10,0"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False" />
                            </Grid>
                        </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <lvc:CartesianChart x:Name="MainChart"
                                        DisableAnimations="True"
                                        LegendLocation="Right"
                                        Series="{Binding MainChartSeries}"
                                        DataClick="MainChart_OnDataClick"
                                        Visibility="{Binding HasRenderableSeries, Converter={StaticResource BoolToVisibilityConverter}}">
                        <lvc:CartesianChart.DataTooltip>
                            <lvc:DefaultTooltip Background="#222" Foreground="White" />
                        </lvc:CartesianChart.DataTooltip>
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Title="{Binding XAxisTitle}" Foreground="Goldenrod" FontSize="12"
                                       Labels="{Binding XLabels}" LabelFormatter="{Binding XAxisFormatter}" LabelsRotation="-45">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Step="{Binding XAxisSeparatorStep}" StrokeThickness="0.25" Stroke="White" StrokeDashArray="15" />
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="{Binding YAxisTitle}" Foreground="Goldenrod" FontSize="12"
                                      MinValue="{Binding YAxisMin}" MaxValue="{Binding YAxisMax}"
                                      LabelFormatter="{Binding YAxisFormatter}">
                                <lvc:Axis.Separator>
                                    <lvc:Separator StrokeThickness="0.25" Stroke="White" StrokeDashArray="15" />
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>

                    <Border Background="#1A282828">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasRenderableSeries}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding EmptyStateMessage}"
                                   Foreground="#88FFFFFF"
                                   FontSize="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MaxWidth="360" />
                    </Border>

                    <Border Background="#F9202020"
                            Panel.ZIndex="10"
                            Padding="20"
                            CornerRadius="6"
                            BorderBrush="#4A90E2"
                            BorderThickness="1"
                            Margin="10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDrillDownOpen}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,15" LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="{Binding DrillDownTitle}" Foreground="White" FontSize="20" FontWeight="Bold" />
                                    <TextBlock Text="{Binding DrillDownSubtitle}" Foreground="#AAAAAA" FontSize="14" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding DrillDownPointSummary}" Foreground="#F4B740" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap" MaxWidth="760" />
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="Close"
                                        Command="{Binding CloseDrillDownCommand}"
                                        Width="80"
                                        Height="30"
                                        Background="#333"
                                        Foreground="White"
                                        BorderBrush="#555"
                                        Cursor="Hand" />
                            </DockPanel>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="280" />
                                </Grid.ColumnDefinitions>

                                <lvc:CartesianChart Grid.Column="0"
                                                    DisableAnimations="True"
                                                    Series="{Binding DrillDownSeries}"
                                                    LegendLocation="Right"
                                                    Margin="0,0,20,0">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Title="Elapsed Time (Minutes)"
                                                  Labels="{Binding DrillDownXLabels}"
                                                  LabelFormatter="{Binding DrillDownXFormatter}"
                                                  Foreground="Goldenrod">
                                            <lvc:Axis.Separator>
                                                <lvc:Separator Stroke="#444" />
                                            </lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis Title="{Binding DrillDownYAxisTitle}"
                                                  Foreground="Goldenrod">
                                            <lvc:Axis.Separator>
                                                <lvc:Separator Stroke="#444" />
                                            </lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisY>
                                    <lvc:CartesianChart.DataTooltip>
                                        <lvc:DefaultTooltip Background="#222" Foreground="White" />
                                    </lvc:CartesianChart.DataTooltip>
                                </lvc:CartesianChart>

                                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding DrillDownStatRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#2A2A35" Margin="0,0,0,8" Padding="12,8" CornerRadius="4">
                                                    <DockPanel>
                                                        <TextBlock Text="{Binding Title}" Foreground="#AAAAAA" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding Value}" Foreground="White" FontWeight="SemiBold" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#FF282828" BorderBrush="#FF444444" BorderThickness="1,0,0,0">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Live Warnings"
                           FontSize="18"
                           Foreground="Goldenrod"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding AlertTiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2E2E3A"
                                        BorderBrush="#555555"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,0,0,12"
                                        Padding="14,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Border Background="{Binding BadgeColor}"
                                                    CornerRadius="3"
                                                    Padding="7,3"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding ClassCode}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="12" />
                                            </Border>
                                            <TextBlock Text="{Binding PriorityLabel}"
                                                       Foreground="#AAAAAA"
                                                       FontSize="11"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>

                                        <TextBlock Text="{Binding SuggestedAction}"
                                                   Foreground="#F4B740"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   LineHeight="18" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
