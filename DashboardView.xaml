                    <!-- Right: time range pills + sensor selector -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="25,0,0,0">

                        <!-- Sensor header picker (same as offline, reused binding) -->
                        <StackPanel Orientation="Vertical" Margin="0,0,25,0">
                            <TextBlock Text="Sensor Headers" Foreground="#8888AA" FontSize="10" Margin="0,0,0,3" />
                            <Grid Height="30" Width="240">
                                <ComboBox Height="30"
                                          Style="{StaticResource TelerikLikeComboBoxStyle}"
                                          Opacity="0.02"
                                          Background="#F2F2F2"
                                          Foreground="Transparent"
                                          BorderBrush="#555555"
                                          Padding="6,2"
                                          ItemsSource="{Binding ComparisonMetricOptions}"
                                          SelectedIndex="-1"
                                          IsTextSearchEnabled="False"
                                          MaxDropDownHeight="320">
                                    <ComboBox.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A35" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#EEEEEE" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#EEEEEE" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3A7AB8" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                    </ComboBox.Resources>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding DisplayName}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Style="{StaticResource SensorHeaderDropdownCheckBoxStyle}"
                                                      Cursor="Hand" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Border Background="#F2F2F2" BorderBrush="#555555" BorderThickness="1" IsHitTestVisible="False">
                                    <Grid>
                                        <TextBlock Text="{Binding SelectedMetricsSummary}" Foreground="#111111"
                                                   Margin="10,0,28,0" Style="{StaticResource SelectedComboOverlayTextStyle}" />
                                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" Foreground="#555555"
                                                   FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- Time-range pills -->
                        <!--<StackPanel Orientation="Vertical">
                            <TextBlock Text="Time Window" Foreground="#8888AA" FontSize="10" Margin="0,0,0,3" />
