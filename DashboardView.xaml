                <RowDefinition Height="0" />
            </Grid.RowDefinitions>

            <!-- ── TOP STATUS BAND ────────────────────────────────────────────── -->
            <Border Grid.Row="0" Background="#0D0D1A" BorderBrush="#2D2D50" BorderThickness="0,0,0,1" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: LIVE badge + file name -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Pulsing LIVE indicator -->
                        <Border Background="#C8173D" CornerRadius="3" Padding="10,4" Margin="0,0,12,0" VerticalAlignment="Center">
                            <TextBlock Text="● LIVE" Foreground="White" FontWeight="Bold" FontSize="13" />
                        </Border>
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock Text="Online Monitoring" Foreground="White" FontSize="15" FontWeight="SemiBold" />
