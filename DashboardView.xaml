                        <StackPanel Width="86" Orientation="Vertical" Margin="0,0,25,0">
                            <TextBlock Text="View Mode" Foreground="#8888AA" FontSize="10" Margin="0,0,0,3" />
                            <Button Width="38" Height="30"
             HorizontalAlignment="Left"
             Style="{StaticResource TelerikLikeIconButtonStyle}"
             Command="{Binding ToggleChartTypeCommand}"
             IsEnabled="{Binding CanToggleChartMode}">
                                <Button.ToolTip>
                                    <ToolTip>
                                        <TextBlock Text="{Binding ChartModeLabel}" Foreground="#F0F0FF" />
                                    </ToolTip>
                                </Button.ToolTip>
                                <Grid>
                                    <Viewbox Width="16" Height="16">
                                        <Canvas Width="24" Height="24">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsBarChartRepresentation}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>
                                            <Rectangle Canvas.Left="3" Canvas.Top="10" Width="4" Height="10" Fill="White" />
                                            <Rectangle Canvas.Left="10" Canvas.Top="5" Width="4" Height="15" Fill="White" />
                                            <Rectangle Canvas.Left="17" Canvas.Top="13" Width="4" Height="7" Fill="White" />
                                        </Canvas>
                                    </Viewbox>
                                    <Viewbox Width="16" Height="16">
                                        <Canvas Width="24" Height="24">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsBarChartRepresentation}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>
                                            <Polyline Points="2,18 7,10 12,14 17,6 22,10"
                               Stroke="White" StrokeThickness="2"
                               StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                               Fill="Transparent" />
                                        </Canvas>
                                    </Viewbox>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── LIVE CHART AREA ─────────────────────────────────────────────── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="300" />
                </Grid.ColumnDefinitions>
                <!-- Live scrolling chart — reuses MainChartSeries which is driven by
                     MergeOnlineCycles() → RefreshAllVisuals() → BuildTimelineSeries() -->
                <lvc:CartesianChart x:Name="OnlineMainChart"
                                    Grid.Column="0"
                                    DisableAnimations="True"
                                    LegendLocation="Right"
                                    Series="{Binding OnlineMainChartSeries}"
                                    DataClick="MainChart_OnDataClick"
                                    Visibility="{Binding HasRenderableSeries, Converter={StaticResource BoolToVisibilityConverter}}">
                    <lvc:CartesianChart.DataTooltip>
                        <lvc:DefaultTooltip Background="#111" Foreground="White" />
                    </lvc:CartesianChart.DataTooltip>
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Foreground="#8888CC" FontSize="11"
                                   Labels="{Binding XLabels}" LabelFormatter="{Binding XAxisFormatter}" LabelsRotation="-40">
                            <lvc:Axis.Separator>
                                <lvc:Separator Step="{Binding XAxisSeparatorStep}" StrokeThickness="0.3" Stroke="#33FFFFFF" StrokeDashArray="8" />
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Foreground="#8888CC" FontSize="11"
                                  MinValue="{Binding YAxisMin}" MaxValue="{Binding YAxisMax}"
                                  LabelFormatter="{Binding YAxisFormatter}">
                            <lvc:Axis.Separator>
                                <lvc:Separator StrokeThickness="0.3" Stroke="#33FFFFFF" StrokeDashArray="8" />
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>

                <!-- Empty state for online mode -->
                <Border Grid.Column="0" Background="#070710">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasRenderableSeries}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Animated waiting dots (CSS-free WPF approach: just text) -->
                        <TextBlock Text="⬤" Foreground="#2D299E" FontSize="40"
                                   HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock.RenderTransform>
                                <ScaleTransform x:Name="PulseTransform" ScaleX="1" ScaleY="1" CenterX="20" CenterY="20"/>
                            </TextBlock.RenderTransform>
                            <TextBlock.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetName="PulseTransform"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             From="0.6" To="1.4" Duration="0:0:1" />
                                            <DoubleAnimation Storyboard.TargetName="PulseTransform"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             From="0.6" To="1.4" Duration="0:0:1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </TextBlock.Triggers>
                        </TextBlock>
                        <TextBlock Text="Waiting for live data…" Foreground="#6666AA" FontSize="20" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Foreground="#44446A" FontSize="13" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="440">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Select sensor headers in the top-right dropdown to begin live plotting.&#x0a;New rows from the watched file will appear here as they arrive." />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasOnlineWatchFile}" Value="False">
                                            <Setter Property="Text" Value="No live file selected. Open Settings and choose a file under Online Mode, then come back here." />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#202020" BorderBrush="#3A3A3A" BorderThickness="1,0,0,0" Padding="16,18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Live Alerts" Foreground="Goldenrod" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,14"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding AlertTiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#2B2B39" BorderBrush="#50505C" BorderThickness="1"
                                                CornerRadius="4" Padding="16,12" Margin="0,0,0,12">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Border Background="{Binding BadgeColor}" CornerRadius="3" Padding="7,3" Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding ClassCode}" Foreground="White" FontWeight="Bold" FontSize="12" />
                                                    </Border>
                                                    <TextBlock Text="{Binding PriorityLabel}" Foreground="#AAAAAA" FontSize="11" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding SuggestedAction}" Foreground="#F4B740" FontSize="12"
                                                           TextWrapping="Wrap" LineHeight="18" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBlock Grid.Row="1" Text="No active live alerts." Foreground="#666666" FontSize="13" VerticalAlignment="Top">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AlertTiles.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── BOTTOM ALERT STRIP ─────────────────────────────────────────── -->
            <Border Grid.Row="2" Background="#0D0D1A" BorderBrush="#2D2D50" BorderThickness="0,1,0,0" Padding="16,8"
                    MaxHeight="140" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Live Alerts" Foreground="Goldenrod" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>

                    <!-- Horizontal scrolling alert strip -->
                    <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding AlertTiles}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A1A2A" BorderBrush="{Binding BadgeColor}"
                                            BorderThickness="1" CornerRadius="4"
                                            Margin="0,0,10,0" Padding="12,8" MinWidth="200" MaxWidth="280">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <Border Background="{Binding BadgeColor}" CornerRadius="3" Padding="6,2" Margin="0,0,6,0">
                                                    <TextBlock Text="{Binding ClassCode}" Foreground="White" FontWeight="Bold" FontSize="11" />
                                                </Border>
                                                <TextBlock Text="{Binding PriorityLabel}" Foreground="#888899" FontSize="10" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding SuggestedAction}" Foreground="#F4B740" FontSize="11"
                                                       TextWrapping="Wrap" LineHeight="15" MaxWidth="260" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- No alerts placeholder -->
                    <TextBlock Grid.Column="1" Text="No active alerts — monitoring normally."
                               Foreground="#444466" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AlertTiles.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
