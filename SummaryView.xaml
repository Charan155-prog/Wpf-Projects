<UserControl x:Class="SterilizationGenie.Views.SummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#FF282828">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" Margin="20,20,20,10" 
                   Text="{Binding SummaryHeaderTitle}" 
                   Foreground="White" FontWeight="Bold" FontSize="20"/>

        <!-- 4 KPI Blocks -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="15,0,15,15">
            <!-- 1. Good Cycles -->
            <Border Background="#27AE60" Margin="5" Padding="15">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding GoodCycleCount}" Foreground="White" FontSize="36" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10" />
                    <TextBlock Text="Good Cycles" Foreground="White" FontSize="14" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
            <!-- 2. Avg Good Duration -->
            <Border Background="#16A085" Margin="5" Padding="15">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding AverageGoodDurationLabel}" Foreground="White" FontSize="36" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10" />
                    <TextBlock Text="Avg Good Duration" Foreground="White" FontSize="14" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
            <!-- 3. Failed Attempts -->
            <Border Background="#C0392B" Margin="5" Padding="15">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding FailedAttemptCount}" Foreground="White" FontSize="36" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10" />
                    <TextBlock Text="Failed Attempts" Foreground="White" FontSize="14" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
            <!-- 4. Peak Failed Duration -->
            <Border Background="#E67E22" Margin="5" Padding="15">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding PeakFailedDurationLabel}" Foreground="White" FontSize="36" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10" />
                    <TextBlock Text="{Binding PeakFailedAttemptLabel}" Foreground="White" FontSize="14" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Data Grid -->
        <DataGrid Grid.Row="2" Background="#FF282828" AutoGenerateColumns="False" ItemsSource="{Binding CycleAttempts}"
                  IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="None" RowHeaderWidth="0"
                  BorderThickness="0" Margin="20,0,20,15">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#132B5E"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Setter Property="BorderBrush" Value="#25427D"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="#FF3A3A3A" />
                    <Setter Property="Foreground" Value="#FFEAEAEA" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Margin" Value="0,1" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Status}" Value="Alarmed">
                            <Setter Property="Background" Value="#A04040" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="Short Run">
                            <Setter Property="Background" Value="#A07240" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="Standby Only">
                            <Setter Property="Background" Value="#505050" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="10,8" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Attempt" Binding="{Binding Attempt}" />
                <DataGridTextColumn Header="Date" Binding="{Binding Date}" />
                <DataGridTextColumn Header="Start" Binding="{Binding Start}" />
                <DataGridTextColumn Header="End" Binding="{Binding End}" />
                <DataGridTextColumn Header="Duration (min)" Binding="{Binding DurationMinutes}" />
                <DataGridTextColumn Header="Max Alarm" Binding="{Binding MaxAlarm}" />
                <DataGridTextColumn Header="Pre-idle Steps" Binding="{Binding PreIdleSteps}" />
                <DataGridTextColumn Header="Recipe Load Step" Binding="{Binding RecipeLoadStep}" />
                <DataGridTemplateColumn Header="Status" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding StatusIcon}" Margin="0,0,5,0" />
                                <TextBlock Text="{Binding Status}" Foreground="White" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Dynamic Insights Footer -->
        <StackPanel Grid.Row="3" Margin="20,0,20,20">
            <TextBlock Text="{Binding SummaryFooterInsight1}" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,4" />
            <TextBlock Text="{Binding SummaryFooterInsight2}" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,4" />
            <TextBlock Text="{Binding SummaryFooterInsight3}" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,4" />
        </StackPanel>
    </Grid>

</UserControl>
